{
  "name": "pomodoro-float",
  "version": "0.1.0",
  "private": true,
  "description": "A frameless floating Pomodoro timer with WebGL ambience, global hotkey, tray controls, and startup support.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "install-startup": "powershell -ExecutionPolicy Bypass -File scripts/install-windows-startup.ps1",
    "remove-startup": "powershell -ExecutionPolicy Bypass -File scripts/remove-windows-startup.ps1"
  },
  "devDependencies": {
    "electron": "^42.0.1"
  }
}
